---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import { Mail, Phone, MapPin, Send, ShieldCheck, FileText, HelpCircle } from 'lucide-react';
---

<Layout title="Support Center">
	<Navbar client:load />
	
	<main class="pt-32 pb-20">
		<div class="max-w-7xl mx-auto px-6">
			<!-- Header -->
			<div class="text-center mb-16">
				<h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Support Center</h1>
				<p class="text-gray-500 max-w-2xl mx-auto text-lg">
					Everything you need to know about our products, policies, and how to get in touch with us.
				</p>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
				<!-- Navigation Sidebar -->
				<aside class="lg:col-span-3">
					<div class="sticky top-40 bg-gray-50 p-6 rounded-3xl border border-gray-100">
						<h3 class="font-bold text-sm uppercase tracking-wider text-gray-400 mb-6 px-2">On This Page</h3>
						<nav class="space-y-1">
							<a href="#contact" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-gray-600 hover:bg-white hover:text-primary transition-all group border border-transparent hover:border-gray-100">
								<Mail size={18} />
								<span class="font-medium">Contact Us</span>
							</a>
							<a href="#privacy" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-gray-600 hover:bg-white hover:text-primary transition-all group border border-transparent hover:border-gray-100">
								<ShieldCheck size={18} />
								<span class="font-medium">Privacy Policy</span>
							</a>
							<a href="#terms" class="flex items-center gap-3 px-4 py-3 rounded-2xl text-gray-600 hover:bg-white hover:text-primary transition-all group border border-transparent hover:border-gray-100">
								<FileText size={18} />
								<span class="font-medium">Terms of Service</span>
							</a>
						</nav>
					</div>
				</aside>

				<!-- Content -->
				<div class="lg:col-span-9 space-y-20">
					<!-- Contact Us Section -->
					<section id="contact" class="scroll-mt-40">
						<div class="flex items-center gap-3 mb-8">
							<div class="sm:w-12 sm:h-12 w-10 h-10 bg-primary/10 rounded-2xl flex items-center justify-center text-primary">
								<Mail size={24} />
							</div>
							<h2 class="text-3xl font-bold">Contact Us</h2>
						</div>

						<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
							<div class="bg-white p-8 rounded-[2rem] border border-gray-100 shadow-sm transition-all hover:shadow-md">
								<h3 class="text-xl font-bold mb-6">Send us a message</h3>
								<form action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
									<input type="hidden" name="access_key" value="f2d1a71c-5e0e-40bf-b3d1-3f20e644a077">
									<input type="hidden" name="subject" value="New Contact Form Submission - Vorazone">
									<input type="hidden" name="from_name" value="Vorazone Support">
									<input type="checkbox" name="botcheck" class="hidden" style="display: none;">

									<div>
										<label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
										<input type="text" name="name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="Your Name" />
									</div>
									<div>
										<label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
										<input type="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="Your Email" />
									</div>
									<div>
										<label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
										<textarea name="message" required rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="How can we help you?"></textarea>
									</div>
									<button type="submit" class="w-full bg-primary text-white font-bold py-4 rounded-xl flex items-center justify-center gap-2 hover:bg-primary-dark transition-all transform hover:scale-[1.02] active:scale-95 shadow-lg shadow-primary/20">
										<Send size={18} />
										Send Message
									</button>
								</form>
							</div>

							<div class="space-y-6">
								<div class="bg-gray-50 p-8 rounded-[2rem] border border-gray-100">
									<h3 class="text-xl font-bold mb-4">Direct Communication</h3>
									<p class="text-gray-500 mb-8 text-sm leading-relaxed">Prefer to talk directly? Reach us through any of these channels our team is ready to assist you.</p>
									<div class="space-y-4">
										<div class="flex items-center gap-4 text-gray-600">
											<div class="w-10 h-10 bg-white rounded-xl border border-gray-100 flex items-center justify-center text-primary shadow-sm"><Mail size={18} /></div>
											<div>
												<p class="text-[10px] uppercase font-bold text-gray-400">Email</p>
												<p class="font-medium text-sm">vorazoneofficial@gmail.com</p>
											</div>
										</div>
										<div class="flex items-center gap-4 text-gray-600">
											<div class="w-10 h-10 bg-white rounded-xl border border-gray-100 flex items-center justify-center text-primary shadow-sm"><Phone size={18} /></div>
											<div>
												<p class="text-[10px] uppercase font-bold text-gray-400">Phone</p>
												<p class="font-medium text-sm">+62 895-4185-19351</p>
											</div>
										</div>
										<div class="flex items-center gap-4 text-gray-600">
											<div class="w-10 h-10 bg-white rounded-xl border border-gray-100 flex items-center justify-center text-primary shadow-sm"><MapPin size={18} /></div>
											<div>
												<p class="text-[10px] uppercase font-bold text-gray-400">Headquarters</p>
												<p class="font-medium text-sm">Madiun, East Java, Indonesia</p>
											</div>
										</div>
									</div>
								</div>
								
								<div class="bg-primary/5 p-8 rounded-[2rem] border border-primary/10">
									<p class="font-bold text-primary mb-2 italic">Fast Response Time</p>
									<p class="text-sm text-gray-600">We typically respond to all inquiries within 24 hours during business days.</p>
								</div>
							</div>
						</div>
					</section>

					<hr class="border-gray-100" />

					<!-- Privacy Policy Section -->
					<section id="privacy" class="scroll-mt-40">
						<div class="flex items-center gap-3 mb-8">
							<div class="sm:w-12 sm:h-12 w-10 h-10 bg-green-50 rounded-2xl flex items-center justify-center text-green-600">
								<ShieldCheck size={24} />
							</div>
							<h2 class="text-3xl font-bold">Privacy Policy</h2>
						</div>
						
						<div class="prose prose-gray max-w-none text-gray-600 space-y-4 leading-relaxed bg-white p-8 rounded-[2rem] border border-gray-50 shadow-sm">
							<p class="font-medium text-gray-900">Effective Date: March 15, 2026</p>
							<p>At Vorazone, we take your privacy seriously. This Privacy Policy describes how your personal information is collected, used, and shared when you visit or make a purchase from our store.</p>
							
							<h4 class="text-lg font-bold text-gray-900 mt-6">1. Personal Information We Collect</h4>
							<p>When you visit the Site, we automatically collect certain information about your device, including information about your web browser, IP address, time zone, and some of the cookies that are installed on your device.</p>
							
							<h4 class="text-lg font-bold text-gray-900 mt-6">2. How We Use Your Personal Information</h4>
							<p>We use the Order Information that we collect generally to fulfill any orders placed through the Site (including processing your payment information, arranging for shipping, and providing you with invoices and/or order confirmations).</p>
							
							<h4 class="text-lg font-bold text-gray-900 mt-6">3. Sharing Your Personal Information</h4>
							<p>We share your Personal Information with third parties to help us use your Personal Information, as described above. For example, we use Shopify to power our online store.</p>
							
							<div class="bg-gray-50 p-6 rounded-2xl mt-8 italic text-sm border-l-4 border-green-500">
								Note: This is a placeholder privacy policy. For a fully professional site, we recommend consulting with a legal professional to draft a policy specific to your business needs.
							</div>
						</div>
					</section>

					<hr class="border-gray-100" />

					<!-- Terms of Service Section -->
					<section id="terms" class="scroll-mt-40">
						<div class="flex items-center gap-3 mb-8">
							<div class="sm:w-12 sm:h-12 w-10 h-10 bg-orange-50 rounded-2xl flex items-center justify-center text-orange-600">
								<FileText size={24} />
							</div>
							<h2 class="text-3xl font-bold">Terms of Service</h2>
						</div>
						
						<div class="prose prose-gray max-w-none text-gray-600 space-y-4 leading-relaxed bg-white p-8 rounded-[2rem] border border-gray-50 shadow-sm">
							<p class="font-medium text-gray-900 mb-6 font-bold uppercase tracking-wider text-sm opacity-60">General Conditions</p>
							
							<h4 class="text-lg font-bold text-gray-900">1. Online Store Terms</h4>
							<p>By agreeing to these Terms of Service, you represent that you are at least the age of majority in your state or province of residence, or that you are the age of majority in your state or province of residence and you have given us your consent to allow any of your minor dependents to use this site.</p>
							
							<h4 class="text-lg font-bold text-gray-900 mt-6">2. Accuracy, Completeness and Timeliness of Information</h4>
							<p>We are not responsible if information made available on this site is not accurate, complete or current. The material on this site is provided for general information only and should not be relied upon or used as the sole basis for making decisions without consulting primary, more accurate, more complete or more timely sources of information.</p>
							
							<h4 class="text-lg font-bold text-gray-900 mt-6">3. Modifications to the Service and Prices</h4>
							<p>Prices for our products are subject to change without notice. We reserve the right at any time to modify or discontinue the Service (or any part or content thereof) without notice at any time.</p>
							
							<div class="bg-gray-50 p-6 rounded-2xl mt-8 italic text-sm border-l-4 border-orange-500">
								Note: These terms are illustrative placeholders. You should review and customize them to fit your specific operations.
							</div>
						</div>
					</section>
				</div>
			</div>
		</div>
	</main>

	<Footer />
</Layout>

<style>
	html {
		scroll-behavior: smooth;
	}
</style>
